POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=replace-with-a-32-plus-character-secret
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-a-different-32-plus-character-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Optional: set this before your first bootstrap run if you already have an n8n activation key.
# N8N_LICENSE_ACTIVATION_KEY=replace-with-your-n8n-license-key

# Optional: keep automatic license renewals enabled unless n8n support tells you otherwise.
# N8N_LICENSE_AUTO_RENEW_ENABLED=true

# Optional: route only n8n license-server traffic through an HTTPS proxy.
# Keep the variable name lowercase to match n8n's expected config key.
# https_proxy_license_server=https://user:pass@proxy.example:8443

# Optional: if your network uses TLS inspection or a private CA, place PEM files in ./pki/
# before starting n8n in bootstrap mode. They mount into /opt/custom-certificates.

# Keep published ports on loopback unless you intentionally expose the stack.
# This controls host bindings on the host-facing edge network.
LOCAL_BIND_ADDRESS=127.0.0.1

# For Mac users running Ollama locally on the host:
# Uncomment this only for the host-Ollama installation path.
# OLLAMA_HOST=host.docker.internal:11434

# Optional Admo integration (ServiceNow XML microservice)
# Enable with: docker compose --profile admo up
ADMO_REPO_PATH=../Admo
ADMO_KNOWLEDGE_ROOT=../Admo-Knowledge-Project
ADMO_PORT=8000
ADMO_QDRANT_COLLECTION=admo_servicenow_xml
